generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Feedback {
  id                  Int      @id @default(autoincrement())
  name                String
  email               String
  message             String
  createdAt           DateTime @default(now())

  telegramStatus      String  @default("pending")
  telegramMessageId  String?
  telegramError       String?
}

