generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Feedback {
  id                  Int      @id @default(autoincrement())
  name                String
  email               String
  message             String
  createdAt           DateTime @default(now())
  telegramStatus      TelegramStatus @default(PENDING)
  telegramMessageId  String?
  telegramError       String?
}

enum TelegramStatus {
  PENDING
  SENT
  FAILED
}

